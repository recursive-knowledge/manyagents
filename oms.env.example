# Oh My Swarm local config template. Copy to `oms.env` (gitignored); the `oms`
# package auto-loads it at import (oms.__init__ -> dotenv.load_dotenv).
# Precedence: CLI flag > process env > oms.env > built-in default.
# Every value below is the built-in default; uncomment to override.
# Tunables are implemented in oms.utils (M1); kept here as the documented seam.

# --- Bank (Supabase) connection (oms.bank, M2) ---
# OMS_BANK_URL=http://127.0.0.1:54421   # 544xx: coexists with sibling datasmith
# OMS_BANK_ANON_KEY=
# OMS_BANK_TRUSTED_KEY=

# --- Curator (oms.distill, M7) ---
# OMS_CURATOR_MODE=auto                 # local | server | auto
# OMS_CURATOR_SERVER_URL=               # hosted curator endpoint (server/auto)
# OMS_DISTILL_TIMEOUT_S=600
# OMS_CROSSDISTILL_WINDOW_DAYS=30
# OMS_CROSS_NUDGE_MIN=3                  # reflections-since-last-bundle before `oms start` nudges /cross-distill
# OMS_REUSE_WEIGHT=1.0

# --- Local LLM fallback (oms.utils.provider, M1; OpenAI-compatible) ---
# OMS_LLM_BASE_URL=
# OMS_LLM_API_KEY=
# OMS_LLM_MODEL=

# --- Capture (oms.capture, M4) ---
# OMS_TRACE_MAX_BYTES=2097152           # 2 * 1024 * 1024

# --- Adapters (oms.adapters, M5) ---
# OMS_ADAPTERS_DIR=                     # local-adapter root: <dir>/<name>/__init__.py

# --- Inject preview (oms.cli /inject, M8) ---
# OMS_INJECT_PREVIEW_HEAD_TOKENS=100
# OMS_INJECT_PREVIEW_TAIL_TOKENS=100

# --- Human surface (oms.cli, M8) ---
# OMS_RATING_PROMPT=1                    # 0 disables the optional ★ prompt
# OMS_NONINTERACTIVE=0                   # 1 = deny-by-default (no inject, unrated)
# OMS_DEFAULT_GOAL=misc                  # goal bucket when `oms start` gets no goal
# OMS_INSTALL_SKILLS=                    # in-agent skill install consent (M11): auto = silent yes,
#                                        # deny = silent no, prompt = always ask (re-offers past a
#                                        # recorded decline). Default: ask once; yes/no is remembered.
# OMS_HOME=~/.oms                        # active-session file + oms state root
# OMS_DEBUG=0                            # 1 = re-raise CLI errors with traceback
# OMS_COLOR=auto                         # CLI color: auto | always | never (NO_COLOR downgrades auto to never)

# --- Read API + viewer (oms.web, M9) ---
# OMS_WEB_PAGE_LIMIT=50                  # default cursor page size
# OMS_WEB_MAX_PAGE_LIMIT=200             # hard cap on ?limit=
# OMS_WEB_HOST=127.0.0.1                 # `make web-up` bind host
# OMS_WEB_PORT=8000                      # `make web-up` bind port
# OMS_WEB_PUBLIC_URL=https://swarms.formulacode.org   # base URL the CLI prints in `open:` links; set EMPTY to derive from OMS_WEB_HOST/PORT
