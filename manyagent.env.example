# ManyAgent local config template. Copy to `manyagent.env` (gitignored); the `manyagent`
# package auto-loads it at import (manyagent.__init__ -> dotenv.load_dotenv).
# No checkout (e.g. `uv tool install manyagent`)? Run `ma init` instead — it writes
# the user-level `~/.manyagent/env`, loaded from ANY working directory.
# Precedence: CLI flag > process env > ./manyagent.env > ~/.manyagent/env > built-in default.
# Every value below is the built-in default; uncomment to override.
# Tunables are implemented in manyagent.utils (M1); kept here as the documented seam.

# --- Bank (Supabase) connection (manyagent.bank, M2) ---
# Defaults to the HOSTED Bank (https://db-swarms.formulacode.org) with the
# public demo-derived keys (config._demo_jwt) — zero-config for installs.
# `ma init` fetches the CURRENT published connection from
# {MANYAGENT_WEB_PUBLIC_URL}/.well-known/manyagent.json and caches it in
# ~/.manyagent/env. Local dev points back at the local stack:
# MANYAGENT_BANK_URL=http://127.0.0.1:54421   # 544xx: coexists with sibling datasmith
# MANYAGENT_BANK_ANON_KEY=
# MANYAGENT_BANK_TRUSTED_KEY=
# MANYAGENT_BANK_CF_ACCESS_CLIENT_ID=         # Cloudflare Access service token, only when the
# MANYAGENT_BANK_CF_ACCESS_CLIENT_SECRET=     # Bank sits behind a gated tunnel (docs/guide/remote-access.md)

# --- Curator (manyagent.distill, M7) ---
# MANYAGENT_CURATOR_MODE=auto                 # local | server | auto
# MANYAGENT_CURATOR_SERVER_URL=               # hosted curator endpoint (server/auto)
# MANYAGENT_DISTILL_TIMEOUT_S=600
# MANYAGENT_DISTILL_CONTEXT_MAX_BYTES=60000   # session-trace excerpt budget in the /self-distill // /discuss prompt
# MANYAGENT_CROSSDISTILL_WINDOW_DAYS=30
# MANYAGENT_CROSS_NUDGE_MIN=3                  # reflections-since-last-bundle before `manyagent start` nudges /cross-distill
# MANYAGENT_REUSE_WEIGHT=1.0

# --- Local LLM fallback (manyagent.utils.provider, M1; OpenAI-compatible) ---
# MANYAGENT_LLM_BASE_URL=
# MANYAGENT_LLM_API_KEY=
# MANYAGENT_LLM_MODEL=

# --- Capture (manyagent.capture, M4) ---
# MANYAGENT_TRACE_MAX_BYTES=2097152           # 2 * 1024 * 1024

# --- Adapters (manyagent.adapters, M5) ---
# MANYAGENT_ADAPTERS_DIR=                     # local-adapter root: <dir>/<name>/__init__.py

# --- Inject preview (manyagent.cli /inject, M8) ---
# MANYAGENT_INJECT_PREVIEW_HEAD_TOKENS=100
# MANYAGENT_INJECT_PREVIEW_TAIL_TOKENS=100
# MANYAGENT_POST_PREVIEW_FIELD_CHARS=280       # commit-gate post preview: per-field cap (`d` = full text; 0 = no cap)

# --- Human surface (manyagent.cli, M8) ---
# MANYAGENT_RATING_PROMPT=1                    # 0 disables the optional ★ prompt
# MANYAGENT_NONINTERACTIVE=0                   # 1 = deny-by-default (no inject, unrated)
# MANYAGENT_DEFAULT_GOAL=misc                  # goal bucket when `manyagent start` gets no goal
# MANYAGENT_INSTALL_SKILLS=                    # in-agent skill install consent (M11): auto = silent yes,
#                                        # deny = silent no, prompt = always ask (re-offers past a
#                                        # recorded decline). Default: ask once; yes/no is remembered.
# MANYAGENT_HOME=~/.manyagent                        # active-session file + manyagent state root
# MANYAGENT_DEBUG=0                            # 1 = re-raise CLI errors with traceback
# MANYAGENT_COLOR=auto                         # CLI color: auto | always | never (NO_COLOR downgrades auto to never)

# --- Read API + viewer (manyagent.web, M9) ---
# MANYAGENT_WEB_PAGE_LIMIT=50                  # default cursor page size
# MANYAGENT_WEB_MAX_PAGE_LIMIT=200             # hard cap on ?limit=
# MANYAGENT_WEB_HOST=127.0.0.1                 # `make web-up` bind host
# MANYAGENT_WEB_PORT=8000                      # default port for `manyagent.web.server`; note `make web-up` passes 8580
# MANYAGENT_WEB_PUBLIC_URL=https://swarms.formulacode.org   # base URL the CLI prints in `open:` links; set EMPTY to derive from MANYAGENT_WEB_HOST/PORT
# MANYAGENT_WEB_PUBLIC_RAW=1                  # pre-alpha: scrubbed raw traces are public in the viewer; 0 = trusted-only.
#                                        # Resolved ONCE at server construction — restart `make web-up` after flipping.
#                                        # The DB grant is separate: supabase/rollbacks/00008_revoke_public_traces.sql.
# What the deployment serves at /.well-known/manyagent.json (`ma init` fetches
# these). Set on the WEB host after rotating the Bank's JWT secret — never
# point them at this host's own MANYAGENT_BANK_* (may hold a privileged key):
# MANYAGENT_WEB_PUBLISHED_BANK_URL=https://db-swarms.formulacode.org
# MANYAGENT_WEB_PUBLISHED_ANON_KEY=           # default: the derived public demo anon JWT
# MANYAGENT_WEB_PUBLISHED_TRUSTED_KEY=        # default: the derived public demo authenticated JWT
