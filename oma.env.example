# Oh My Agent local config template. Copy to `oma.env` (gitignored); the `oma`
# package auto-loads it at import (oma.__init__ -> dotenv.load_dotenv).
# Precedence: CLI flag > process env > oma.env > built-in default.
# Every value below is the built-in default; uncomment to override.
# Tunables are implemented in oma.utils (M1); kept here as the documented seam.

# --- Bank (Supabase) connection (oma.bank, M2) ---
# OMA_BANK_URL=http://127.0.0.1:54421   # 544xx: coexists with sibling datasmith
# OMA_BANK_ANON_KEY=
# OMA_BANK_TRUSTED_KEY=

# --- Curator (oma.distill, M7) ---
# OMA_CURATOR_MODE=auto                 # local | server | auto
# OMA_CURATOR_SERVER_URL=               # hosted curator endpoint (server/auto)
# OMA_DISTILL_TIMEOUT_S=600
# OMA_CROSSDISTILL_WINDOW_DAYS=30
# OMA_REUSE_WEIGHT=1.0

# --- Local LLM fallback (oma.utils.provider, M1; OpenAI-compatible) ---
# OMA_LLM_BASE_URL=
# OMA_LLM_API_KEY=
# OMA_LLM_MODEL=

# --- Capture (oma.capture, M4) ---
# OMA_TRACE_MAX_BYTES=2097152           # 2 * 1024 * 1024

# --- Adapters (oma.adapters, M5) ---
# OMA_ADAPTERS_DIR=                     # local-adapter root: <dir>/<name>/__init__.py

# --- Inject preview (oma.cli /inject, M8) ---
# OMA_INJECT_PREVIEW_HEAD_TOKENS=100
# OMA_INJECT_PREVIEW_TAIL_TOKENS=100

# --- Human surface (oma.cli, M8) ---
# OMA_RATING_PROMPT=1                    # 0 disables the optional ★ prompt
# OMA_NONINTERACTIVE=0                   # 1 = deny-by-default (no inject, unrated)
# OMA_HOME=~/.oma                        # active-session file + oma state root
# OMA_DEBUG=0                            # 1 = re-raise CLI errors with traceback

# --- Read API + viewer (oma.web, M9) ---
# OMA_WEB_PAGE_LIMIT=50                  # default cursor page size
# OMA_WEB_MAX_PAGE_LIMIT=200             # hard cap on ?limit=
# OMA_WEB_HOST=127.0.0.1                 # `make web-up` bind host
# OMA_WEB_PORT=8000                      # `make web-up` bind port
